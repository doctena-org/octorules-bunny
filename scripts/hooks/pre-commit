#!/usr/bin/env bash
# Pre-commit hook: lint and format check.
#
# Install: from the repo root, run:
#   ln -sf ../../scripts/hooks/pre-commit .git/hooks/pre-commit
set -euo pipefail

.venv/bin/pip install -e ".[dev]" -q
.venv/bin/ruff check octorules_bunny/ tests/
.venv/bin/ruff format --check octorules_bunny/ tests/
